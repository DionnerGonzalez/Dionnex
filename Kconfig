#
# DionOS Main Kernel Configuration Menu
#

mainmenu "Dionnex Modular Monolithic Kernel v1.0.0 Configuration"

config DIONOS_VERSION
	string
	default "1.0.0-RELEASE"

menu "Target Architecture Setup"

choice
	prompt "Target Architecture"
	default ARCH_X86_64
	help
	  Select the CPU target architecture for the build.

config ARCH_X86_64
	bool "x86_64 Architecture"
	help
	  Build for 64-bit x86 Intel/AMD processors.

config ARCH_X86_32
	bool "x86 32-bit Architecture"

config ARCH_ARM64
	bool "ARM64 Architecture (AArch64)"

config ARCH_ARM32
	bool "ARM 32-bit Architecture (ARMv7)"

config ARCH_RISCV64
	bool "RISC-V 64-bit Architecture"

config ARCH_POWERPC
	bool "PowerPC Architecture"

config ARCH_MIPS
	bool "MIPS Architecture"

config ARCH_SPARC
	bool "SPARC Architecture"

config ARCH_S390
	bool "IBM System/390 Architecture"

config ARCH_LOONGARCH
	bool "LoongArch Architecture"

endchoice

endmenu

menu "Core Subsystems & Execution Engine"

config PREEMPT
	bool "Preemptive Kernel Model"
	default y
	help
	  Enable full kernel preemption for low latency response times.

config SCHED_CFS
	bool "Completely Fair Scheduler (CFS)"
	default y

config SCHED_RT
	bool "Real-Time POSIX Schedulers (FIFO/RR)"
	default y

config NUMA
	bool "Non-Uniform Memory Access (NUMA) Support"
	default y

config KASLR
	bool "Kernel Address Space Layout Randomization"
	default y

config MODULES
	bool "Modular Kernel Subsystem Support"
	default y
	help
	  Allow dynamic runtime loading of kernel driver modules.

endmenu

menu "Memory Subsystem Configuration"

config SLUB
	bool "SLUB Memory Allocator"
	default y

config HUGE_PAGES
	bool "HugeTLB / Transparent Huge Pages"
	default y

config MMU
	bool "Hardware Memory Management Unit"
	default y

endmenu
